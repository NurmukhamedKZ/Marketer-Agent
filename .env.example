# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://mktg:password@localhost:5432/mktg_agent
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=mktg-agent/0.1 by /u/yourusername
REDDIT_SUBREDDITS=SaaS,startups,Entrepreneur,smallbusiness
REDDIT_KEYWORDS=how do I,alternative to,anyone using,looking for,recommend,struggling with
REDDIT_MAX_AGE_HOURS=48
REDDIT_MIN_SCORE=2

# X (Twitter) API (https://developer.x.com)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=0

# Tavily Web Search (https://tavily.com)
TAVILY_API_KEY=tvly-...

# Agent behavior
CMO_IDEAS_PER_RUN=3
CMO_SIGNAL_CANDIDATES=15
POST_MAX_CHARS=270
SUB_AGENT_MAX_ITERATIONS=8

# Seed data — one user + one product_kb created at deploy (MVP)
SEED_USER_TELEGRAM_ID=0
SEED_USER_EMAIL=
SEED_PRODUCT_NAME=
SEED_PRODUCT_ONE_LINER=
SEED_PRODUCT_DESCRIPTION=
SEED_PRODUCT_ICP=
SEED_PRODUCT_BRAND_VOICE=
SEED_PRODUCT_LANDING_URL=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
